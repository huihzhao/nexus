# ══════════════════════════════════════════════════════════════════════
# Rune Nexus — Environment Configuration
# ══════════════════════════════════════════════════════════════════════
# Nexus can run standalone (CLI / demo) or be imported by Server.
# When running standalone, configure the keys below.
# When running via Server, Server's .env provides these at runtime.

# ── LLM ──────────────────────────────────────────────────────────────
TWIN_LLM_PROVIDER=gemini
TWIN_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Tools ────────────────────────────────────────────────────────────
# TAVILY_API_KEY=
# JINA_API_KEY=

# ── Twin Identity ────────────────────────────────────────────────────
TWIN_NAME=My Nexus
TWIN_OWNER=
TWIN_AGENT_ID=my-twin
TWIN_DATA_DIR=.rune_twin

# ── Chain Mode (optional — leave RUNE_PRIVATE_KEY empty for local mode) ──
RUNE_PRIVATE_KEY=
RUNE_NETWORK=bsc-testnet
RUNE_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
RUNE_TESTNET_AGENT_STATE_ADDRESS=0x10d87b8A82E86923c3d8D617888e47af6C1813D4
RUNE_TESTNET_TASK_MANAGER_ADDRESS=0x892Ee992c352b3E69d52b3449460E4dddC291293
RUNE_TESTNET_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
RUNE_MAINNET_RPC=https://bsc-dataseed1.bnbchain.org
RUNE_MAINNET_IDENTITY_REGISTRY=0xfA09B3397fAC75424422C4D28b1729E3D4f659D7

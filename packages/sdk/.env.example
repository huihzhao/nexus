# ══════════════════════════════════════════════════════════════════════
# Rune Protocol SDK — Environment Configuration
# ══════════════════════════════════════════════════════════════════════
# The SDK is independently usable. Configure the keys for the features you use.
# Only fill in what you need — everything is optional.

# ── LLM Client ───────────────────────────────────────────────────────
# Required if you use LLMClient directly (e.g., from bnbchain_agent.llm)
TWIN_LLM_PROVIDER=gemini
TWIN_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Tools ────────────────────────────────────────────────────────────
# Required if you use WebSearchTool or URLReaderTool
# TAVILY_API_KEY=
# JINA_API_KEY=

# ── Chain Mode ───────────────────────────────────────────────────────
# Required if you use ChainBackend (BSC + Greenfield).
# Leave empty to use LocalBackend (file-based, no chain).
RUNE_PRIVATE_KEY=
RUNE_NETWORK=bsc-testnet

# BSC Testnet (public addresses)
RUNE_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
RUNE_TESTNET_AGENT_STATE_ADDRESS=0x7D62c0685bc75a566E795f17b664aa86DeE0b48b
RUNE_TESTNET_TASK_MANAGER_ADDRESS=0x1FDf86470E9000C08d6A40a208be877D22C013da
RUNE_TESTNET_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e

# BSC Mainnet
RUNE_MAINNET_RPC=https://bsc-dataseed1.bnbchain.org
RUNE_MAINNET_IDENTITY_REGISTRY=0xfA09B3397fAC75424422C4D28b1729E3D4f659D7

# Greenfield (optional — falls back to local storage if not set)
# RUNE_GREENFIELD_BUCKET=rune-agent-state

# ── Contract Deployment (one-time, delete after use) ─────────────────
# DEPLOYER_PRIVATE_KEY=0x...
# BSCSCAN_API_KEY=...

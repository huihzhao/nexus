# ══════════════════════════════════════════════════════════════════════
# Rune Server — Environment Configuration
# ══════════════════════════════════════════════════════════════════════
# Server is a standalone API gateway. It does NOT import Nexus or run
# DigitalTwin. It only uses SDK's LLMClient for LLM proxying and has
# its own chain integration for agent registration.

# ── Server ───────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
SERVER_SECRET=change-me-to-a-random-string
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Authentication ───────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Rune Protocol
WEBAUTHN_ORIGIN=http://localhost:3000
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LLM Gateway ─────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Tool Execution (server runs tools on behalf of clients) ──────────
# TAVILY_API_KEY=
# JINA_API_KEY=

# ── Chain Proxy ──────────────────────────────────────────────────────
# Server signs on-chain transactions on behalf of users.
# SERVER_PRIVATE_KEY=0x...
# CHAIN_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# CHAIN_AGENT_CONTRACT_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_LLM_REQUESTS_PER_MINUTE=60
RATE_LIMIT_OTHER_REQUESTS_PER_MINUTE=120

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./rune_server.db

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>RuneDesktop.Core</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.*" />
    <!-- System.Text.Json is part of the .NET 10 framework (Microsoft.NET.Sdk
         implicitly references it). Listing it explicitly triggers NU1510
         and pins us to a version that may lag behind the framework's. -->
  </ItemGroup>
</Project>

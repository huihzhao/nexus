<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RuneDesktop.UI.Views"
        x:Class="RuneDesktop.UI.Views.MainWindow"
        Title="Nexus"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        Background="{StaticResource SurfaceBaseBrush}"
        x:Name="RootWindow">

  <Grid RowDefinitions="48,*">

    <!-- Top Bar -->
    <Border Grid.Row="0"
            Background="{StaticResource SurfaceMutedBrush}"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource DividerBrush}"
            Padding="16,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <!-- Sidebar toggle (Cmd+\\). Hides/shows the entire session
               rail — cleanest pattern for "I just want the chat
               surface, no chrome". When the rail is hidden, this
               button is the only way back. -->
          <Button Classes="ghost"
                  IsVisible="{Binding IsLoggedIn}"
                  Command="{Binding SessionsVm.ToggleHiddenCommand}"
                  ToolTip.Tip="Toggle session rail (Ctrl+\)"
                  Padding="6,2"
                  FontSize="14">
            <TextBlock Text="☰"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
          </Button>
          <!-- Activity sidebar toggle. Hides/shows the chat surface's
               internal 320 px column (identity card + state counters
               + Browse buttons + activity stream). When hidden the
               chat takes the full width up to the cognition column —
               same pattern as Claude / Cowork's collapsible side
               panes. -->
          <Button Classes="ghost"
                  IsVisible="{Binding IsLoggedIn}"
                  Command="{Binding ChatVm.ToggleActivityHiddenCommand}"
                  ToolTip.Tip="Toggle activity sidebar"
                  Padding="6,2"
                  FontSize="13">
            <TextBlock Text="▤"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
          </Button>
          <Border Width="28" Height="28" CornerRadius="6"
                  Background="{StaticResource BrandAccentBrush}">
            <TextBlock Text="N" FontSize="15" FontWeight="Bold"
                       Foreground="{StaticResource TextOnAccentBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Nexus"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    Spacing="12" VerticalAlignment="Center">
          <!-- Cognition panel toggle (Cmd+Shift+\\). Hides the right
               side column when the user wants more chat real estate. -->
          <Button Classes="ghost"
                  IsVisible="{Binding IsLoggedIn}"
                  Command="{Binding ChatVm.Cognition.ToggleHiddenCommand}"
                  ToolTip.Tip="Toggle cognition panel (Ctrl+Shift+\)"
                  Padding="6,2"
                  FontSize="13">
            <TextBlock Text="◧"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
          </Button>
          <!-- ERC-8004 token id pill — only when registered on chain -->
          <Border IsVisible="{Binding ChatVm.IsOnChain}"
                  CornerRadius="999" Padding="10,3"
                  BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                  Background="#1B3220"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Your ERC-8004 token id on BSC">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="ERC-8004" FontSize="10" FontWeight="Bold"
                         Foreground="{StaticResource SuccessBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding ChatVm.ChainTokenId}"
                         FontSize="11" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontFamily="Consolas, Menlo, monospace"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Only render StatusText when there's something noteworthy
               to show (mid-bootstrap, errors, etc.). Happy-path silence
               keeps the top bar from duplicating the ERC-8004 pill +
               user pill. -->
          <TextBlock Text="{Binding StatusText}" FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" MaxWidth="380"
                     IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <StackPanel Orientation="Horizontal" Spacing="10"
                      IsVisible="{Binding IsLoggedIn}"
                      ToolTip.Tip="{Binding UserId}">
            <Border Width="28" Height="28" CornerRadius="14"
                    Background="{StaticResource AccentClaudeBrush}">
              <TextBlock Text="{Binding UserInitial, FallbackValue=?}"
                         Foreground="{StaticResource TextOnAccentBrush}"
                         FontSize="12" FontWeight="SemiBold"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Orientation="Vertical" Spacing="0"
                        VerticalAlignment="Center">
              <TextBlock Text="{Binding UserName, FallbackValue=Unknown}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis" MaxWidth="180"/>
              <TextBlock Text="{Binding UserShortId}"
                         FontSize="10"
                         FontFamily="Menlo, Consolas, monospace"
                         Foreground="{StaticResource TextTertiaryBrush}"
                         TextTrimming="CharacterEllipsis" MaxWidth="180"/>
            </StackPanel>
            <Button Content="Sign out" Command="{Binding LogoutCommand}"
                    Classes="ghost" FontSize="12" Padding="6,2"/>
          </StackPanel>
        </StackPanel>
        <Panel/>
      </DockPanel>
    </Border>

    <!-- Content -->
    <Panel Grid.Row="1">
      <!-- First-run wizard: occludes everything else when ShowWelcome
           is true. Set on startup if the user hasn't configured a
           server URL yet, or when they click the gear icon on Login.
           IMPORTANT: We wrap WelcomeView in a Panel so IsVisible can
           bind against MainViewModel (the inherited DataContext)
           while the inner WelcomeView's DataContext is explicitly
           overridden to WelcomeVm. Without the wrapper, the
           IsVisible binding tries to resolve `ShowWelcome` on
           WelcomeVm — which doesn't have that property — and
           silently evaluates to false (gear-button-does-nothing bug). -->
      <Panel IsVisible="{Binding ShowWelcome}">
        <views:WelcomeView DataContext="{Binding WelcomeVm}"/>
      </Panel>

      <!-- Login: visible when configured but not logged in. Same
           wrapper trick as above — Panel evaluates ShowWelcome /
           IsLoggedIn against MainViewModel. -->
      <Panel>
        <Panel.IsVisible>
          <MultiBinding Converter="{x:Static BoolConverters.And}">
            <Binding Path="ShowWelcome"
                     Converter="{x:Static BoolConverters.Not}"/>
            <Binding Path="IsLoggedIn"
                     Converter="{x:Static BoolConverters.Not}"/>
          </MultiBinding>
        </Panel.IsVisible>
        <views:LoginView DataContext="{Binding LoginVm}"/>
      </Panel>

      <!-- Logged-in surface: session rail (left, collapsible) +
           ChatView (everything right of it). ChatView keeps its own
           3-column inner layout (state sidebar / chat / cognition);
           we don't reach into it from here. -->
      <Grid IsVisible="{Binding #RootWindow.DataContext.IsLoggedIn}"
            ColumnDefinitions="Auto,Auto,*">
        <!-- Rail visibility = NOT IsHidden. When hidden, the
             SessionRailView control's IsVisible is false; its
             Width binding to RailWidth (which returns 0 when hidden)
             also collapses the column track entirely. -->
        <views:SessionRailView Grid.Column="0"
                               DataContext="{Binding SessionsVm}"
                               IsVisible="{Binding SessionsVm.IsHidden,
                                           Converter={x:Static BoolConverters.Not}}"/>
        <!-- Splitter between session rail and ChatView. Hidden when
             the rail is collapsed to icon strip (dragging makes no
             sense at 60px) OR completely hidden. -->
        <GridSplitter Grid.Column="1" Width="4"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"
                      Background="{StaticResource DividerBrush}"
                      HorizontalAlignment="Stretch">
          <GridSplitter.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="SessionsVm.IsCollapsed"
                       Converter="{x:Static BoolConverters.Not}"/>
              <Binding Path="SessionsVm.IsHidden"
                       Converter="{x:Static BoolConverters.Not}"/>
            </MultiBinding>
          </GridSplitter.IsVisible>
        </GridSplitter>
        <views:ChatView Grid.Column="2"
                        DataContext="{Binding ChatVm}"/>
      </Grid>
    </Panel>

    <!-- Chain-degradation toast. Floats top-right above the content
         row when ToastVisible flips true. Self-clears after 8s via the
         DispatcherTimer in MainViewModel.OnChainDegradation. The
         visible→hidden transition is binding-driven so we don't need
         a behavior or animation. -->
    <Border Grid.Row="1"
            IsVisible="{Binding ToastVisible}"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,16,16,0"
            Padding="14,10" CornerRadius="8"
            Background="{StaticResource SurfaceCardBrush}"
            BorderBrush="{StaticResource WarningBrush}"
            BorderThickness="1"
            MaxWidth="380"
            BoxShadow="0 4 14 0 #66000000">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="⚠"
                   FontSize="16"
                   Foreground="{StaticResource WarningBrush}"
                   VerticalAlignment="Top"/>
        <StackPanel Spacing="2" MaxWidth="320">
          <TextBlock Text="Chain sync degraded"
                     FontSize="12" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding ToastMessage}"
                     FontSize="11"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>

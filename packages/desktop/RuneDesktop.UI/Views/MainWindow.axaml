<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RuneDesktop.UI.Views"
        x:Class="RuneDesktop.UI.Views.MainWindow"
        Title="Rune Protocol"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="640"
        Background="{StaticResource SurfaceBaseBrush}"
        x:Name="RootWindow">

  <Grid RowDefinitions="48,*">

    <!-- Top Bar -->
    <Border Grid.Row="0"
            Background="{StaticResource SurfaceMutedBrush}"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource DividerBrush}"
            Padding="16,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <Border Width="28" Height="28" CornerRadius="6"
                  Background="{StaticResource BrandAccentBrush}">
            <TextBlock Text="R" FontSize="15" FontWeight="Bold"
                       Foreground="{StaticResource TextOnAccentBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Rune Protocol"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    Spacing="12" VerticalAlignment="Center">
          <!-- ERC-8004 token id pill — only when registered on chain -->
          <Border IsVisible="{Binding ChatVm.IsOnChain}"
                  CornerRadius="999" Padding="10,3"
                  BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                  Background="#1B3220"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Your ERC-8004 token id on BSC">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="ERC-8004" FontSize="10" FontWeight="Bold"
                         Foreground="{StaticResource SuccessBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding ChatVm.ChainTokenId}"
                         FontSize="11" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontFamily="Consolas, Menlo, monospace"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <TextBlock Text="{Binding StatusText}" FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" MaxWidth="380"/>

          <StackPanel Orientation="Horizontal" Spacing="8"
                      IsVisible="{Binding IsLoggedIn}">
            <Border Width="26" Height="26" CornerRadius="13"
                    Background="{StaticResource AccentClaudeBrush}">
              <TextBlock Text="{Binding UserName, FallbackValue=?}"
                         Foreground="{StaticResource TextOnAccentBrush}"
                         FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Button Content="Sign out" Command="{Binding LogoutCommand}"
                    Classes="ghost" FontSize="12" Padding="6,2"/>
          </StackPanel>
        </StackPanel>
        <Panel/>
      </DockPanel>
    </Border>

    <!-- Content -->
    <Panel Grid.Row="1">
      <views:LoginView DataContext="{Binding LoginVm}"
                       IsVisible="{Binding #RootWindow.DataContext.IsLoggedIn,
                                  Converter={x:Static BoolConverters.Not}}"/>
      <views:ChatView DataContext="{Binding ChatVm}"
                      IsVisible="{Binding #RootWindow.DataContext.IsLoggedIn}"/>
    </Panel>
  </Grid>
</Window>

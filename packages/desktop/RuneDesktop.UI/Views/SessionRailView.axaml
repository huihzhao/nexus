<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RuneDesktop.UI.ViewModels"
             x:Class="RuneDesktop.UI.Views.SessionRailView"
             x:DataType="vm:SessionListViewModel"
             Background="{StaticResource SurfaceMutedBrush}">

  <!--
    Left rail. Two visual modes driven by IsCollapsed:
      * collapsed (60px) — round avatar buttons, just first-letter
      * expanded  (240px) — title + subtitle + relative time
    Both modes share the same Sessions ItemsControl; visibility on
    the title/subtitle stack is gated on IsCollapsed.
    Outer Border.Width is bound to RailWidth (a derived double on
    the VM) so the column animates without needing a converter.
  -->

  <Border BorderThickness="0,0,1,0"
          BorderBrush="{StaticResource DividerBrush}"
          Width="{Binding RailWidth}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

      <!-- ─── New chat button ─────────────────────────────────────── -->
      <Border Grid.Row="0" Padding="10,12,10,8">
        <Panel>
          <!-- Expanded form: full-width labelled button -->
          <Button Command="{Binding NewSessionCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Background="{StaticResource BrandAccentBrush}"
                  Foreground="{StaticResource TextOnAccentBrush}"
                  CornerRadius="6"
                  Padding="10,8"
                  FontSize="13" FontWeight="SemiBold"
                  IsVisible="{Binding !IsCollapsed}"
                  ToolTip.Tip="Start a new chat thread (Ctrl+N)">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                         VerticalAlignment="Center"/>
              <TextBlock Text="New chat" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <!-- Collapsed form: just the + glyph -->
          <Button Command="{Binding NewSessionCommand}"
                  Background="{StaticResource BrandAccentBrush}"
                  Foreground="{StaticResource TextOnAccentBrush}"
                  CornerRadius="6"
                  Width="32" Height="32"
                  Padding="0"
                  FontSize="16" FontWeight="Bold"
                  HorizontalAlignment="Center"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  IsVisible="{Binding IsCollapsed}"
                  ToolTip.Tip="Start a new chat thread (Ctrl+N)">
            <TextBlock Text="+"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Button>
        </Panel>
      </Border>

      <!-- ─── Sessions header (expanded only) ─────────────────────── -->
      <TextBlock Grid.Row="1"
                 Text="SESSIONS"
                 FontSize="10" FontWeight="Bold"
                 Foreground="{StaticResource TextTertiaryBrush}"
                 Margin="14,8,14,4"
                 IsVisible="{Binding !IsCollapsed}"/>

      <!-- ─── Session list ────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="2"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Padding="0,0,0,4">
        <ItemsControl ItemsSource="{Binding Sessions}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:SessionItemViewModel">
              <Grid ColumnDefinitions="*,Auto">
                <!-- Click target: select the session. Double-click on
                     the same row enters inline rename mode (handled in
                     code-behind). Default sessions can't be renamed
                     so the double-click is silently ignored for them. -->
                <Button Grid.Column="0"
                        Classes="session-row"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Tag="{Binding Id}"
                        Click="OnSessionRowClicked"
                        DoubleTapped="OnSessionRowDoubleTapped"
                        ToolTip.Tip="{Binding Title}">
                  <Border Padding="10,7"
                          CornerRadius="6"
                          Margin="6,1"
                          Background="Transparent">
                    <Grid ColumnDefinitions="Auto,*">
                      <!-- Avatar circle (always visible). Note: NO
                           right margin — at 60px collapsed-rail width
                           the row only has ~28px of usable width
                           (after 6 px row margin + 10 px row Border
                           padding on each side), so any extra margin
                           would shove the avatar past the edge and
                           clip the initial. The expanded form gets
                           its avatar→title gap from the title
                           StackPanel's own left margin instead. -->
                      <Border Grid.Column="0"
                              Width="28" Height="28"
                              CornerRadius="6"
                              Background="{StaticResource AccentClaudeBrush}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Initial}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextOnAccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                      <!-- Title + subtitle (expanded only) -->
                      <StackPanel Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Spacing="2"
                                  Margin="10,0,0,0"
                                  IsVisible="{Binding $parent[UserControl].((vm:SessionListViewModel)DataContext).IsCollapsed,
                                              Converter={x:Static BoolConverters.Not}}">
                        <!-- Display mode: read-only title -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding !IsRenaming}"/>
                        <!-- Edit mode: inline TextBox. Enter commits,
                             Esc cancels (handled in code-behind). The
                             AttachedToVisualTree handler also focuses
                             + selects the box on appearance so the
                             user can type immediately. -->
                        <TextBox Text="{Binding EditingTitle, Mode=TwoWay}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="Transparent"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="{StaticResource BrandAccentBrush}"
                                 Padding="0,0,0,2"
                                 Margin="0"
                                 MinHeight="0"
                                 Tag="{Binding Id}"
                                 KeyDown="OnSessionRenameKeyDown"
                                 LostFocus="OnSessionRenameLostFocus"
                                 AttachedToVisualTree="OnSessionRenameAttached"
                                 IsVisible="{Binding IsRenaming}"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>

                <!-- Delete button (× glyph) — hidden for the synthetic
                     default session, AND hidden in collapsed (60px) rail
                     mode where there's no room for it next to the
                     avatar without overlapping. Click triggers a
                     confirmation toast; confirming hard-deletes via the
                     server + wipes EventLog + clears WAL. BSC anchors
                     stay immutable as expected. -->
                <Button Grid.Column="1"
                        Classes="session-delete"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,4"
                        Margin="0,1,8,1"
                        Tag="{Binding Id}"
                        Click="OnSessionRowDeleteClicked"
                        ToolTip.Tip="Delete this session (irreversible)">
                  <Button.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                      <Binding Path="IsDefault"
                               Converter="{x:Static BoolConverters.Not}"/>
                      <Binding Path="$parent[UserControl].((vm:SessionListViewModel)DataContext).IsCollapsed"
                               Converter="{x:Static BoolConverters.Not}"/>
                    </MultiBinding>
                  </Button.IsVisible>
                  <TextBlock Text="✕"
                             FontSize="13"
                             Foreground="{StaticResource TextTertiaryBrush}"/>
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- ─── Footer: archived toggle + collapse handle ──────────── -->
      <Border Grid.Row="3"
              BorderThickness="0,1,0,0"
              BorderBrush="{StaticResource DividerBrush}"
              Padding="8,8,8,10">
        <Grid ColumnDefinitions="*,Auto">
          <Button Grid.Column="0"
                  Content="Show archived"
                  Command="{Binding ToggleArchivedCommand}"
                  Classes="ghost" FontSize="11"
                  HorizontalAlignment="Left"
                  IsVisible="{Binding !IsCollapsed}"/>
          <Button Grid.Column="1"
                  Command="{Binding ToggleCollapseCommand}"
                  Classes="ghost" FontSize="14"
                  Padding="6,2"
                  IsVisible="{Binding !IsCollapsed}"
                  ToolTip.Tip="Collapse the session rail (Ctrl+\)">
            <TextBlock Text="«"/>
          </Button>
          <Button Grid.Column="0" Grid.ColumnSpan="2"
                  Command="{Binding ToggleCollapseCommand}"
                  Classes="ghost" FontSize="14"
                  HorizontalAlignment="Center"
                  Padding="6,2"
                  IsVisible="{Binding IsCollapsed}"
                  ToolTip.Tip="Expand the session rail (Ctrl+\)">
            <TextBlock Text="»"/>
          </Button>
        </Grid>
      </Border>

    </Grid>
  </Border>

</UserControl>

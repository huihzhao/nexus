<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <LangVersion>latest</LangVersion>
    <RootNamespace>RuneDesktop.UI</RootNamespace>
  </PropertyGroup>

  <PropertyGroup>
    <!-- App identity for the OS dock / taskbar / Start menu.
         AssemblyTitle / Product control the human-readable name; the
         actual dock raster comes from the .ico / .icns produced by
         scripts/build-icon.sh, wired in via the conditional ItemGroup
         below so a fresh checkout still builds even before you've run
         the icon-build step. -->
    <AssemblyTitle>Nexus</AssemblyTitle>
    <Product>Nexus</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.*" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.*" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.*" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.*" />
    <!-- Lets us use the SVG asset as the in-app window icon without
         pre-building a raster. The OS dock icon still uses the .ico /
         .icns generated by scripts/build-icon.sh. -->
    <PackageReference Include="Avalonia.Svg.Skia" Version="11.3.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../RuneDesktop.Core/RuneDesktop.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
    <!-- Always-present source-of-truth icon. The build-icon.sh script
         derives the platform raster files from this. -->
    <AvaloniaResource Include="Assets/nexus-logo.svg" />
  </ItemGroup>

  <!-- Optional raster icons — only include them if they've been
       generated. This way a fresh checkout still builds before
       scripts/build-icon.sh is run; once you do run the script, the
       next build picks up the .ico / .icns / .png automatically. -->
  <ItemGroup Condition="Exists('Assets/nexus-icon.ico')">
    <AvaloniaResource Include="Assets/nexus-icon.ico" />
  </ItemGroup>
  <ItemGroup Condition="Exists('Assets/nexus-icon.png')">
    <AvaloniaResource Include="Assets/nexus-icon.png" />
  </ItemGroup>
  <ItemGroup Condition="Exists('Assets/nexus-icon.icns')">
    <AvaloniaResource Include="Assets/nexus-icon.icns" />
  </ItemGroup>
  <PropertyGroup Condition="Exists('Assets/nexus-icon.ico')">
    <ApplicationIcon>Assets/nexus-icon.ico</ApplicationIcon>
  </PropertyGroup>
</Project>

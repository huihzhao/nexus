# ══════════════════════════════════════════════════════════════════════
# Nexus server — PRODUCTION env config
# ══════════════════════════════════════════════════════════════════════
# Copy to .env.production and edit. NEVER commit the real file.
#
# Critical to-do checklist before first `docker compose up`:
#   [ ] Set HOSTNAME to <your-public-ip-with-dashes>.nip.io
#   [ ] Generate SERVER_SECRET — `openssl rand -hex 32`
#   [ ] Set GEMINI_API_KEY (or your other LLM provider keys)
#   [ ] Set CORS_ALLOW_ORIGINS to your hostname (or "*" for permissive)
#   [ ] Decide if you want chain integration on (SERVER_PRIVATE_KEY etc.)

# ── Public-facing hostname (used by Caddy + WebAuthn) ────────────────
# Pattern: <ip-with-dashes>.nip.io  e.g. 1-2-3-4.nip.io  (free, no DNS
# config needed — nip.io resolves arbitrary "1-2-3-4" to 1.2.3.4).
HOSTNAME=1-2-3-4.nip.io

# ── Server ───────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
ENVIRONMENT=production
LOG_LEVEL=INFO

# REQUIRED — used to sign JWTs. If you change this all existing tokens
# become invalid (every user has to re-login). Generate with:
#   openssl rand -hex 32
SERVER_SECRET=CHANGE-ME-RUN-openssl-rand-hex-32

# ── Authentication (WebAuthn passkey) ────────────────────────────────
# The RP_ID must be exactly the hostname WITHOUT scheme/port. The
# ORIGIN must be the full https:// URL. WebAuthn binds credentials to
# the RP_ID, so this MUST match what users see in their address bar
# during registration — change it later and all passkeys break.
WEBAUTHN_RP_ID=1-2-3-4.nip.io
WEBAUTHN_RP_NAME=Nexus
WEBAUTHN_ORIGIN=https://1-2-3-4.nip.io

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── CORS ─────────────────────────────────────────────────────────────
# Allow the desktop's WebView (which loads the passkey ceremony page
# from the same hostname) and the desktop client itself. The desktop
# uses a non-browser HTTP client so CORS doesn't strictly apply to it,
# but the WebView does need this.
CORS_ALLOW_ORIGINS=https://1-2-3-4.nip.io

# ── LLM Gateway ─────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Tool execution (server runs tools on the agent's behalf) ─────────
# Web search via Tavily. Without this, agent's web_search tool returns
# "no API key" and agent has to fall back to URL reading.
TAVILY_API_KEY=
# Higher-quality URL extraction (free tier works without key).
JINA_API_KEY=

# ── Chain integration (BSC + Greenfield) ─────────────────────────────
# Set these to put agents on-chain. Without them, the server runs in
# "local mode" — twins still work but ERC-8004 / Greenfield / state
# anchors are skipped. Chain mode is required for the full immortal-
# agent guarantees.
#
# SERVER_PRIVATE_KEY=0x...
# CHAIN_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# NEXUS_NETWORK=bsc_testnet
# CHAIN_AGENT_CONTRACT_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ── Persistence (don't usually need to touch in Docker) ──────────────
# Defaults set inside the Dockerfile point at /data on the volume:
#   NEXUS_TWIN_BASE_DIR=/data/twins
#   UPLOAD_DIR=/data/uploads
#   NEXUS_CACHE_DIR=/data/cache
#   DATABASE_URL=sqlite:////data/db/rune_server.db

# ── Rate limiting ────────────────────────────────────────────────────
# Per-user, per-minute. Tune if you have heavy usage. The "other"
# bucket covers everything except /llm/chat.
RATE_LIMIT_LLM_REQUESTS_PER_MINUTE=60
RATE_LIMIT_OTHER_REQUESTS_PER_MINUTE=120
